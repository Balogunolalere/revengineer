# ============================================================================
# DeepSeek Revengineer — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and should NEVER be committed.

# ---------- DeepSeek Authentication (pick ONE method) ----------

# Option 1: Bearer token (from grab_token.py or browser DevTools)
DEEPSEEK_TOKEN=

# Option 2: Email / password login (only for email-registered accounts)
DEEPSEEK_EMAIL=
DEEPSEEK_PASSWORD=

# ---------- API Server settings ----------
API_HOST=0.0.0.0
API_PORT=8000

# ---------- Instagram Bot ----------
IG_USERNAME=you@example.com
IG_PASSWORD=your-password

# ---------- OpenRouter (free vision models) ----------
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ---------- NVIDIA NIM (free preview vision models) ----------
# Get a free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...
